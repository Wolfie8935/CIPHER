# CIPHER — LLM Backend
# All other settings live in cipher/utils/config.py with sensible defaults.

HF_TOKEN=hf_token_here
API_BASE_URL=https://router.huggingface.co/v1

# ── Dashboard backend URL ──────────────────────────────────────────────────
# Set to the URL where the Flask API server is running.
# If this points to an HF Space (*.hf.space or huggingface.co/spaces/...),
# main.py will automatically push live data and rewards to HF Dataset so the
# HF Space dashboard reflects your local training in real-time.
BACKEND_URL=http://localhost:5001

# ── HuggingFace Space (deployed environment) ──────────────────────────────
HF_SPACE_URL=https://huggingface.co/spaces/wolfie8935/cipher-openenv

# ── Optional: push episode traces to HF Dataset after each episode ────────
# Requires write access token in HF_TOKEN above.
# Set automatically when BACKEND_URL points to HF Space.
# CIPHER_PUSH_TRACES_HF=1
# HF_TRACES_REPO=wolfie8935/cipher-traces
