# ============================================================
# CIPHER — LLM BACKEND CONFIGURATION
# ============================================================

# ── Backend selector ─────────────────────────────────────────
# Options: hf | local | hybrid
#   hf     → HuggingFace Inference API (default)
#   local  → OpenAI-compatible local server (LM Studio / vllm)
#   hybrid → RED Planner uses LoRA from disk, rest use HF
LLM_BACKEND=hf

# ── Execution mode ───────────────────────────────────────────
# stub → fast weighted-random actions, no API cost (~0.01 s/ep)
# live → real LLM calls via selected backend
LLM_MODE=stub

# ── HuggingFace Inference API ────────────────────────────────
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=
HF_BASE_URL=https://api-inference.huggingface.co/v1/

# RED team — strategic planner/analyst use Mistral-7B;
# fast action agents use Qwen2.5-7B (cheaper, faster)
HF_MODEL_RED_PLANNER=mistralai/Mistral-7B-Instruct-v0.3
HF_MODEL_RED_ANALYST=mistralai/Mistral-7B-Instruct-v0.3
HF_MODEL_RED_OPERATIVE=Qwen/Qwen2.5-7B-Instruct
HF_MODEL_RED_EXFIL=Qwen/Qwen2.5-7B-Instruct

# BLUE team
HF_MODEL_BLUE_SURV=Qwen/Qwen2.5-7B-Instruct
HF_MODEL_BLUE_HUNTER=mistralai/Mistral-7B-Instruct-v0.3
HF_MODEL_BLUE_DECEIVER=mistralai/Mistral-7B-Instruct-v0.3
HF_MODEL_BLUE_FORENSICS=mistralai/Mistral-7B-Instruct-v0.3

# Oversight judge (slightly more capable)
HF_MODEL_OVERSIGHT=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Your fine-tuned model (post-training) ────────────────────
HF_MODEL_RED_CUSTOM=wolfie8935/cipher-red-planner-grpo

# ── Local model server (optional, for hybrid mode) ───────────
# LM Studio default: http://localhost:1234/v1
# vllm default:      http://localhost:8000/v1
LOCAL_MODEL_URL=http://localhost:1234/v1    
LOCAL_MODEL_NAME=cipher-red-planner

# ── LoRA adapter paths (for hybrid competition mode) ─────────
RED_PLANNER_LORA_PATH=red trained/cipher-red-planner-v1
RED_ANALYST_LORA_PATH=red trained/cipher-red-analyst-v1
BLUE_SURVEILLANCE_LORA_PATH=blue trained/cipher-blue-surveillance-v1
BLUE_THREAT_HUNTER_LORA_PATH=blue trained/cipher-blue-threat-hunter-v1
