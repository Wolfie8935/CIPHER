# ============================================================
# CIPHER — LLM BACKEND CONFIGURATION  (v2 commander + subagents)
# Copy to .env and fill in HF_TOKEN.
# ============================================================

# ── Backend selector ─────────────────────────────────────────
# Options: hf | local | hybrid
#   hf     → HuggingFace Inference API (default for --live)
#   local  → OpenAI-compatible local server (LM Studio / vllm)
#   hybrid → RED/BLUE Commanders + key specialists use LoRA from disk,
#            other subagents use HF
LLM_BACKEND=hf

# ── Execution mode ───────────────────────────────────────────
# stub   → fast weighted-random / heuristic actions, no API cost (~0.01s/ep)
# live   → real LLM calls via the selected backend (used by --live)
# hybrid → RED Planner LoRA + HF for everything else (used by --hybrid)
LLM_MODE=stub

# ── HuggingFace Inference API ────────────────────────────────
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1

# ============================================================
# v2 ARCHITECTURE — Commander + Dynamic Subagents
# ============================================================
# v2 = single RED + single BLUE commander spawning subagents on demand
# v1 = legacy fixed 4 RED + 4 BLUE roster (kept for emergency rollback only)
CIPHER_AGENT_ARCH=v2

# ── Commander LLMs (top-level RED/BLUE brains) ───────────────
HF_MODEL_RED_COMMANDER=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_BLUE_COMMANDER=meta-llama/Llama-3.1-8B-Instruct

# ── Subagent population caps ─────────────────────────────────
# Concurrent alive subagents per commander (hard cap).
ENV_MAX_SUBAGENTS_RED=6
ENV_MAX_SUBAGENTS_BLUE=6
# Total spawns the commander can issue per episode (budget).
ENV_SUBAGENT_SPAWN_BUDGET_RED=12
ENV_SUBAGENT_SPAWN_BUDGET_BLUE=12
# Default lifespan (steps) before a subagent is auto-dismissed.
ENV_SUBAGENT_DEFAULT_LIFESPAN=5

# ── Reward shaping (delegation efficiency) ───────────────────
# When true: adds delegation_efficiency_bonus & spawn_cost_penalty to rewards.
# Keep false until you've trained the commander baseline.
ENV_REWARD_DELEGATION_ENABLED=false

# ============================================================
# Subagent specialist LLMs  (used when subagent.use_llm=true)
# ============================================================
# RED specialist subagents — strategic roles use Llama-3.1-8B; fast tactical
# roles can use Qwen2.5-7B for speed/cost.
HF_MODEL_RED_PLANNER=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_RED_ANALYST=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_RED_OPERATIVE=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_RED_EXFIL=meta-llama/Llama-3.1-8B-Instruct

# BLUE specialist subagents
HF_MODEL_BLUE_SURV=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_BLUE_HUNTER=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_BLUE_DECEIVER=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_BLUE_FORENSICS=meta-llama/Llama-3.1-8B-Instruct

# ── Oversight Auditor (9th LLM — judges every episode) ───────
HF_MODEL_OVERSIGHT=meta-llama/Llama-3.1-8B-Instruct

# ── Public fine-tuned model (RED Planner GRPO from your HF) ──
HF_MODEL_RED_CUSTOM=wolfie8935/cipher-red-planner-grpo

# ── Local model server (optional, for hybrid local routing) ──
# LM Studio default: http://localhost:1234/v1
# vllm default:      http://localhost:8000/v1
LOCAL_MODEL_URL=http://localhost:1234/v1
LOCAL_MODEL_NAME=cipher-red-planner

# ============================================================
# LoRA adapters — used when --hybrid (or LLM_MODE=hybrid).
# Paths are relative to the project root.
# ============================================================
# Commander LoRAs (trained by cipher_training_v2_commander.ipynb)
RED_COMMANDER_LORA_PATH=red trained/cipher-red-commander-v1
BLUE_COMMANDER_LORA_PATH=blue trained/cipher-blue-commander-v1

# Specialist subagent LoRAs (legacy roles trained by older notebooks).
# These are still loaded by Subagent instances when use_llm=true and
# the role matches a known specialist.
RED_PLANNER_LORA_PATH=red trained/cipher-red-planner-v1
RED_ANALYST_LORA_PATH=red trained/cipher-red-analyst-v1
BLUE_SURVEILLANCE_LORA_PATH=blue trained/cipher-blue-surveillance-v1
BLUE_THREAT_HUNTER_LORA_PATH=blue trained/cipher-blue-threat-hunter-v1
